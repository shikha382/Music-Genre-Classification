    "import soundfile as sf\n",
    "\n",
    "# 5 second mix using RAW audio\n",
    "stems_audio = []\n",
    "\n",
    "for stem_file in STEMS:\n",
    "    path = os.path.join(DATA_ROOT,'rock',first_song,stem_file)\n",
    "    \n",
    "    y, sr = sf.read(path)\n",
    "    \n",
    "    # take only first 5 seconds manually\n",
    "    y = y[:int(5*SR)]\n",
    "    \n",
    "    stems_audio.append(y)\n",
    "\n",
    "# ensure equal length\n",
    "min_len = min(len(s) for s in stems_audio)\n",
    "stems_audio = [s[:min_len] for s in stems_audio]\n",
    "\n",
    "stems_stack = np.vstack(stems_audio)\n",
    "\n",
    "mix_raw = np.sum(stems_stack, axis=0)\n",
    "\n",
    "print(\"Q12:\", round(np.max(np.abs(mix_raw)),2))\n"
   ]
