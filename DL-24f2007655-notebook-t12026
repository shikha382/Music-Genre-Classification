 random.randint(0, F-f)\n        x[:, f0:f0+f] = 0\n    if random.random() < 0.5:\n        t = int(T * tp); t0 = random.randint(0, T-t)\n        x[t0:t0+t, :] = 0\n    return x\nprint(\"specaugment ready\")","metadata":{"tags":[],"trusted":true,"execution":{"iopub.status.busy":"2026-03-30T19:43:58.330238Z","iopub.status.idle":"2026-03-30T19:43:58.330524Z","shell.execute_reply.started":"2026-03-30T19:43:58.330396Z","shell.execute_reply":"2026-03-30T19:43:58.330410Z"}},"outputs":[],"execution_count":null},{"id":"c10","cell_type":"code","source":"ast_extractor = ASTFeatureExtractor.from_pretrained(\"MIT/ast-finetuned-audioset-10-10-0.4593\")\nast_model = ASTForAudioClassification.from_pretrained(\n    \"MIT/ast-finetuned-audioset-10-10-0.4593\",\n    num_labels=N_LABELS, id2label=id2label, label2id=label2id,\n    ignore_mismatched_sizes=True\n).to(DEVICE)\nprint(\"AST loaded\")","metadata":{"tags":[],"trusted":true,"execution":{"iopub.status.busy":"2026-03-30T19:43:58.332125Z","iopub.status.idle":"2026-03-30T19:43:58.332560Z","shell.execute_reply.started":"2026-03-30T19:43:58.332317Z","shell.execute_reply":"2026-03-30T19:43:58.332357Z"}},"outputs":[],"execution_count":null},{"id":"c11","cell_type":"code","source":"class ASTDataset(Dataset):\n    def __init__(self, idx, extractor, size=TRAIN_SIZE):\n        self.idx = idx; self.ext = extractor; self.size = size\n    def __len__(self): return self.size\n    def __getitem__(self, _):\n        g = random.choice(GENRES)\n        p = random.choice(self.idx[g])\n        v = load_audio(f\"{p}/vocals.wav\")\n        d = load_audio(f\"{p}/drums.wav\")\n        b = load_audio(f\"{p}/bass.wav\")\n        a = normalize(v*0.5 + d*0.3 + b*0.2)\n        a = crop_random(a)\n        inp = self.ext(a, sampling_rate=SR, return_tensors=\"pt\")\n        x = spec_augment(inp.input_values.squeeze(0))\n        return {\"input_values\": x, \"labels\": torch.tensor(label2id[g])}\nprint(\"ASTDataset ready\")","metadata":{"tags":[],"trusted":true,"execution":{"iopub.status.busy":"2026-03-30T19:43:58.333195Z","iopub.status.idle":"2026-03-30T19:43:58.333593Z","shell.execute_reply.started":"2026-03-30T19:43:58.333392Z","shell.execute_reply":"2026-03-30T19:43:58.333413Z"}},"outputs":[],"execution_count":null},{"id":"c12","cell_type":"code","source":"class ASTValDataset(Dataset):\n    def __init__(self, idx, extractor):\n        self.ext = extractor\n        self.samples = [(p,g) for g in GENRES for p in idx[g]]\n    def __len__(self): return len(self.samples)\n    def __getitem__(self, i):\n        p, g = self.samples[i]\n        stems = [load_audio(f\"{p}/{s}\") for s in STEMS]\n        a = normalize(stems[0]*0.5 + stems[1]*0.3 + stems[2]*0.2)\n        a = crop_center(a)\n        inp = self.ext(a, sampling_rate=SR, return_tensors=\"pt\")\n        return {\"input_values\": inp.input_values.squeeze(0), \"labels\": torch.tensor(label2id[g])}\nprint(\"ASTValDataset ready\")","metadata":{"tags":[],"trusted":true,"execution":{"iopub.status.busy":"2026-03-30T19:43:58.334230Z","iopub.status.idle":"2026-03-30T19:43:58.334555Z","shell.execute_reply.started":"2026-03-30T19:43:58.334399Z","shell.execute_reply":"2026-03-30T19:43:58.334418Z"}},"outputs":[],"execution_count":null},{"id":"c13","cell_type":"code","source":"ast_train_dl = DataLoader(\n    ASTDataset(train_idx, ast_extractor),\n    batch_size=BATCH, shuffle=True,\n    num_workers=4, pin_memory=True,\n    persistent_workers=True, prefetch_factor=2\n)\nast_val_dl = DataLoader(\n    ASTValDataset(val_idx, ast_extractor),\n    batch_size=BATCH*2, shuffle=False,\n    num_workers=4, pin_memory=True,\n    persistent_workers=True, prefetch_factor=2\n)\nprint(f\"AST dataloaders  train={len(ast_train_dl)}  val={len(ast_val_dl)}\")","metadata":{"tags":[],"trusted":true,"execution":{"iopub.status.busy":"2026-03-30T19:43:58.335724Z","iopub.status.idle":"2026-03-30T19:43:58.336069Z","shell.execute_reply.started":"2026-03-30T19:43:58.335934Z","shell.execute_reply":"2026-03-30T19:43:58.335961Z"}},"outputs":[],"execution_count":null},{"id":"c14","cell_type":"code","source":"criterion = nn.CrossEntropyLoss(label_smoothing=0.1)\nf1_metric = MulticlassF1Score(num_classes=N_LABELS, average=\"macro\").to(DEVICE)\nscaler    = GradScaler(enabled=USE_AMP)\n\ndef train_epoch(model, dl, opt, sched):\n    model.train(); total_loss = 0\n    for i, batch in enumerate(dl):\n        inp = batch[\"input_values\"].to(DEVICE, non_blocking=True)\n        lab = batch[\"labels\"].to(DEVICE, non_blocking=True)\n        with autocast(enabled=USE_AMP):\n            loss = criterion(model(inp).logits, lab) / GRAD_ACC\n        scaler.scale(loss).backward()\n        if (i + 1) % GRAD_ACC == 0:\n            scaler.unscale_(opt)\n            torch.nn.utils.clip_grad_norm_(model.parameters(), 1.0)\n            scaler.step(opt); scaler.update(); opt.zero_grad(set_to_none=True)\n            if sched: sched.step()\n        total_loss += loss.item() * GRAD_ACC\n    return total_loss / len(dl)\n\ndef val_epoch(model, dl):\n    model.eval(); f1_metric.reset()\n    with torch.no_grad():\n        for batch in dl:\n            inp = batch[\"input_values\"].to(DEVICE, non_blocking=True)\n            lab = batch[\"labels\"].to(DEVICE, non_blocking=True)\n            with autocast(enabled=USE_AMP):\n                logits = model(inp).logits\n            f1_metric.update(logits, lab)\n    return f1_metric.compute().item()\n\nprint(\"train/val epoch functions ready  (AMP + set_to_none)\")","metadata":{"tags":[],"trusted":true,"execution":{"iopub.status.busy":"2026-03-30T19:43:58.337111Z","iopub.status.idle":"2026-03-30T19:43:58.337544Z","shell.execute_reply.started":"2026-03-30T19:43:58.337305Z","shell.execute_reply":"2026-03-30T19:43:58.337351Z"}},"outputs":[],"execution_count":null},{"id":"c15","cell_type":"code","source":"for p in ast_model.base_model.parameters(): p.requires_grad = False\nopt1   = torch.optim.AdamW(filter(lambda p: p.requires_grad, ast_model.parameters()), lr=LR1)\nsched1 = get_cosine_schedule_with_warmup(opt1, 50, len(ast_train_dl)*EP1//GRAD_ACC)\nbest_p1 = 0\nast_history = {\"loss\": [], \"f1\": []}\nfor ep in range(EP1):\n    tl = train_epoch(ast_model, ast_train_dl, opt1, sched1)\n    vf = val_epoch(ast_model, ast_val_dl)\n    ast_history[\"loss\"].append(tl)\n    ast_history[\"f1\"].append(vf)\n    print(f\"P1 ep{ep+1} loss={tl:.3f} f1={vf:.4f}\")\n    if vf > best_p1:\n        best_p1 = vf\n        torch.save(ast_model.state_dict(), \"/kaggle/working/ast_p1.pth\")","metadata":{"tags":[],"trusted":true,"execution":{"iopub.status.busy":"2026-03-30T19:43:58.338845Z","iopub.status.idle":"2026-03-30T19:43:58.339092Z","shell.execute_reply.started":"2026-03-30T19:43:58.338973Z","shell.execute_reply":"2026-03-30T19:43:58.338986Z"}},"outputs":[],"execution_count":null},{"id":"c16","cell_type":"code","source":"ast_model.load_state_dict(torch.load(\"/kaggle/working/ast_p1.pth\"))\nfor p in ast_model.parameters(): p.requires_grad = True\nopt2 = torch.optim.AdamW([\n    {\"params\": ast_model.base_model.parameters(), \"lr\": LR2},\n    {\"params\": ast_model.classifier.parameters(), \"lr\": LR2*10}\n])\nsched2 = get_cosine_schedule_with_warmup(opt2, 100, len(ast_train_dl)*EP2//GRAD_ACC)\nbest_ast = 0\nast_p2_history = {\"loss\": [], \"f1\": []}\nfor ep in range(EP2):\n    tl = train_epoch(ast_model, ast_train_dl, opt2, sched2)\n    vf = val_epoch(ast_model, ast_val_dl)\n    ast_p2_history[\"loss\"].append(tl)\n    ast_p2_history[\"f1\"].append(vf)\n    print(f\"P2 ep{ep+1} loss={tl:.3f} f1={vf:.4f}\")\n    if vf > best_ast:\n        best_ast = vf\n        torch.save(ast_model.state_dict(), \"/kaggle/working/ast_best.pth\")\nprint(f\"AST best f1: {best_ast:.4f}\")","metadata":{"tags":[],"trusted":true,"execution":{"iopub.status.busy":"2026-03-30T19:43:58.340156Z","iopub.status.idle":"2026-03-30T19:43:58.340539Z","shell.execute_reply.started":"2026-03-30T19:43:58.340316Z","shell.execute_reply":"2026-03-30T19:43:58.340351Z"}},"outputs":[],"execution_count":null},{"id":"c17","cell_type":"code","source":"def tta_predict(model, extractor, audio, n=N_TTA):\n    crops  = [extractor(crop_random(audio), sampling_rate=SR,\n               return_tensors=\"pt\").input_values.to(DEVICE, non_blocking=True)\n              for _ in range(n)]\n    batch  = torch.cat(crops, dim=0)  # (n, T)\n    with torch.no_grad(), autocast(enabled=USE_AMP):\n        logits = model(batch).logits          # (n, C)\n    probs = F.softmax(logits, dim=-1).float().cpu().numpy()\n    return probs.mean(axis=0)\nprint(\"tta_predict ready\")","metadata":{"tags":[],"trusted":true,"execution":{"iopub.status.busy":"2026-03-30T19:43:58.341726Z","iopub.status.idle":"2026-03-30T19:43:58.341975Z","shell.execute_reply.started":"2026-03-30T19:43:58.341863Z","shell.execute_reply":"2026-03-30T19:43:58.341876Z"}},"outputs":[],"execution_count":null},{"id":"hub_h","cell_type":"markdown","source":"## HuBERT","metadata":{"tags":[]}},{"id":"h01","cell_type":"code","source":"hub_proc  = Wav2Vec2FeatureExtractor.from_pretrained(\"facebook/hubert-base-ls960\")\nhub_model = HubertForSequenceClassification.from_pretrained(\n    \"facebook/hubert-base-ls960\",\n    num_labels=N_LABELS, id2label=id2label, label2id=label2id,\n    ignore_mismatched_sizes=True\n).to(DEVICE)\nprint(\"HuBERT loaded\")","metadata":{"tags":[],"trusted":true,"execution":{"iopub.status.busy":"2026-03-30T19:43:58.343731Z","iopub.status.idle":"2026-03-30T19:43:58.344132Z","shell.execute_reply.started":"2026-03-30T19:43:58.344007Z","shell.execute_reply":"2026-03-30T19:43:58.344022Z"}},"outputs":[],"execution_count":null},{"id":"h02","cell_type":"code","source":"class SimpleDataset(Dataset):\n    def __init__(self, idx, proc, size=3000):\n        self.idx = idx; self.proc = proc; self.size = size\n    def __len__(self): return self.size\n    def __getitem__(self, _):\n        g = random.choice(GENRES)\n        p = random.choice(self.idx[g])\n        v = load_audio(f\"{p}/vocals.wav\")